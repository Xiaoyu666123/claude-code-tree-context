{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\inject-tree-context.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\update-tree.ps1\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
